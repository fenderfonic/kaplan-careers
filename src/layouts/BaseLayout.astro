---
import { META_TITLE, META_DESCRIPTION, OG_TITLE, OG_DESCRIPTION } from '../config/site';

interface Props {
  title?: string;
  description?: string;
}
const { title = META_TITLE, description = META_DESCRIPTION } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
<!-- Basic Meta Tag -->
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge, chrome=1">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta name="MobileOptimized" content="width">
	<meta name="HandheldFriendly" content="true">
	<meta name="apple-mobile-web-app-capable" content="yes">
	<meta http-equiv="cleartype" content="on">

<!-- Custom Meta Tag -->
	<meta name="description" content={description}>
	<meta name="author" content="Kaplain International">
	<meta name="keywords" content="">
	<meta name="page-type" content="gcpn_kaplan-new-campaign">

<!-- Open Graph -->
	<meta property="og:title" content={OG_TITLE} />
	<meta property="og:description" content={OG_DESCRIPTION} />
	<meta property="og:type" content="Website" />
	<meta property="og:url" content="//careers.kaplaninternational.com" />
	<meta property="og:image" content="//careers.kaplaninternational.com/dist/images/business-kaplan-int-english.jpg" />

<!-- Canonical Tag -->
	<link rel="canonical" href="//careers.kaplaninternational.com" />

<!-- Favicon -->
	<link rel="icon" type="image/x-icon" href="//study.kaplaninternational.com/favicon.ico" />

<!-- Page title -->
	<title>{title}</title>

<!-- Style default: do not remove -->


	<!-- IE10 viewport hack for Surface/desktop Windows 8 bug -->
	<script is:inline src="dist/js/ie10-viewport-bug-workaround.js"></script>
	<!-- HTML5 shim and Respond.js IE8 support of HTML5 elements and media queries -->
	<!--[if lt IE 9]>
	<script src="dist/js/html5shiv.min.js"></script>
	<script src="dist/js/respond.min.js"></script>
	<![endif]-->

<!-- Optimizely Tag -->
	<script is:inline src="//cdn.optimizely.com/js/4238035597.js"></script>

<!-- FORM: HEAD SECTION -->

<!-- Google Tag Manager -->
<script is:inline>(function (w, d, s, l, i) {
		w[l] = w[l] || []; w[l].push({
			'gtm.start':
				new Date().getTime(), event: 'gtm.js'
		}); var f = d.getElementsByTagName(s)[0],
			j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =
				'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);
	})(window, document, 'script', 'dataLayer', 'GTM-T7R98LC');</script>
<!-- End Google Tag Manager -->

<!-- Global Style -->
	<link href="/dist/css/bootstrap.min.css" rel="stylesheet">
	<link href="/dist/css/style.css" rel="stylesheet">

</head>

<body>

	<!-- Google Tag Manager (noscript) -->
	<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T7R98LC" height="0" width="0"
			style="display:none;visibility:hidden"></iframe></noscript>
	<!-- End Google Tag Manager (noscript) -->

	<slot />

	<!-- BASIC -->
	<script is:inline type="text/javascript" src="//ajax.googleapis.com/ajax/libs/jquery/1.11.1/jquery.min.js"></script>
	<script is:inline type="text/javascript" src="/dist/js/scripts.min.js"></script>
	<script is:inline type="text/javascript" src="/dist/js/bootstrap.min.js"></script>

	<!-- Cookie Banner -->
	<script is:inline>var cookieLanguage = "en";</script>
	<script is:inline src="//assetlibs.kaplaninternational.com/_assets/cookie-banner/js/cookieconsent.min.js"></script>
</body>
</html>
