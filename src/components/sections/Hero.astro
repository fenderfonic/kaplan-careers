---
// src/components/sections/Hero.astro
---
<section id="hero" class="hero" aria-label="Hero">
  <!-- Video background -->
  <!-- EXTERNAL_DEP: /video/ki-career.mp4 — source from Kaplan brand team -->
  <div class="hero-video" aria-hidden="true">
    <video
      class="hero-video__el"
      autoplay
      muted
      loop
      playsinline
      preload="none"
    >
      <source src="/video/ki-career.mp4" type="video/mp4" />
    </video>
    <!-- Fallback: dark overlay always shown; video layers above on supported browsers -->
  </div>

  <!-- Overlay -->
  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- Content -->
  <div class="hero-content container">
    <div class="hero-text reveal">
      <h1 class="hero-h1">Join our global team</h1>
      <h2 class="hero-h2">
        Learn more about our education business<br />
        to see where you could apply your skills
      </h2>
      <p class="hero-cta-wrap">
        <button
          class="btn btn-xl btn-skyblue hero-cta"
          data-modal="location-modal"
          aria-haspopup="dialog"
        >
          Current opportunities
        </button>
      </p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a href="#overview" class="hero-scroll scroll-link" aria-label="Scroll to overview">
    <span class="hero-scroll__arrow" aria-hidden="true"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--color-navy-darkest);
  }

  /* Video */
  .hero-video {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-video__el {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 50%;
  }

  /* Dark gradient overlay */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(18,27,96,0.55) 0%,
      rgba(2,3,10,0.65) 100%
    );
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-block: var(--space-32);
  }
  .hero-text {
    max-width: 800px;
    margin-inline: auto;
  }

  .hero-h1 {
    font-size: var(--text-hero);
    font-weight: 900;
    color: var(--color-white);
    letter-spacing: var(--tracking-tight);
    text-shadow: 0 2px 16px rgba(2,3,10,0.4);
    margin-bottom: var(--space-6);
    line-height: 1.1;
  }

  .hero-h2 {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-weight: 300;
    color: rgba(255,255,255,0.9);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-10);
    text-shadow: 0 1px 8px rgba(2,3,10,0.3);
  }

  .hero-cta-wrap {
    margin: 0;
  }

  /* Scroll arrow */
  .hero-scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: rgba(255,255,255,0.7);
  }
  .hero-scroll__arrow {
    display: block;
    width: 20px;
    height: 20px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
    animation: bounce 1.6s ease-in-out infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: rotate(45deg) translateY(0); }
    50%       { transform: rotate(45deg) translateY(6px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-scroll__arrow { animation: none; }
  }
</style>
