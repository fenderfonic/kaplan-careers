---
// src/components/sections/CareerAreas.astro
// Accordion: clicking a tile expands a full-width panel. One open at a time.
// Vanilla JS + ARIA. Smooth height transition.

const areas = [
  {
    id: 'teaching',
    title: 'Teaching & Academic',
    image: '/images/area-teaching.jpg',
    description:
      "When asked about their experience of studying at Kaplan International, it's so often the great teachers that our students remember — the teacher who spent extra time after class explaining a difficult concept, the teacher whose lessons stimulated their interest in learning or the teacher who offered advice when they were feeling homesick. Our teachers all share a passion for bringing learning alive and seeing their students develop and grow.",
  },
  {
    id: 'operations',
    title: 'Operations',
    image: '/images/area-operations.jpg',
    description:
      "Our schools and colleges around the world welcome students from over 100 countries. So whether it's helping on the student services desk with orientation, advising and assisting with accommodation questions, supporting the academic teams with scheduling and timetabling or helping students to enrol for the right exams, our teams get involved in all aspects of the student experience. The one thing that all our operations staff share is a genuine interest in helping students and a desire to deliver an exceptional customer service experience.",
  },
  {
    id: 'technology',
    title: 'Technology',
    image: '/images/area-technology.jpg',
    description:
      "Technology is at the heart of everything we do – from our global website in more than 15 languages and booking engines through to our operations management system and student portal delivering information to our customers around the world. Whether it's developing new systems to enhance our business or supporting our users across the different areas of the business, Kaplan International offers a stimulating work environment for a wide range of technology professionals.",
  },
  {
    id: 'sales',
    title: 'Sales',
    image: '/images/area-sales.jpg',
    description:
      "We work with B2B customers including agents and corporates as well as individual travellers and students wanting to enrol on our programmes. Our salespeople are responsible for maintaining and growing existing markets and opening up new ones in places we may not have worked before. Salespeople who thrive in our business are those who really understand their customers, are endlessly curious about their markets and are alert to the new opportunities as or even before they emerge.",
  },
  {
    id: 'customer-service',
    title: 'Customer Service',
    image: '/images/area-customer-service.jpg',
    description:
      "Whether it's advising a German student on where they can learn English and enjoy the best beach life or counselling a Chinese high school student on the most suitable UK engineering degree programme, the quality of our customer service particularly before students enrol and travel is a cornerstone of our business. We employ multilingual staff with great interpersonal skills and a passion for helping people, ensuring high levels of loyalty from our B2B and B2C customers around the world.",
  },
  {
    id: 'admissions',
    title: 'Admissions',
    image: '/images/area-admissions.jpg',
    description:
      "Admissions staff provide key support to students before and after enrolment onto our academic programmes. As well as being good at dealing with people, the role requires in-depth knowledge of our courses and locations and an awareness of immigration requirements. The admissions process can take a matter of months so there's a great opportunity to develop a strong rapport with our customers and become a key sounding board as they prepare for their study abroad journey.",
  },
  {
    id: 'marketing',
    title: 'Marketing',
    image: '/images/area-marketing.jpg',
    description:
      "As a global marketer, where better to enjoy a career than at the world's largest global education provider which promotes its products and services in more than 100 countries? With a portfolio of products which are changing and evolving to meet the needs of our customers and a growing range of channels through which to communicate with our global audience, Kaplan International can provide a stimulating place to forge a career in international marketing.",
  },
  {
    id: 'finance',
    title: 'Finance',
    image: '/images/area-finance.jpg',
    description:
      "As a multinational business operating across 4 continents, doing business in different currencies, we can offer excellent opportunities for a stimulating and varied career in Finance – whether it's working with our partners in the area of credit control, supporting the accounting for our schools and colleges or being part of our global financial control, planning and analysis team. Our accounting team is made up of staff across the experience and qualification spectrum and reflects the international mix found in other parts of the company.",
  },
  {
    id: 'hr',
    title: 'Human Resources',
    image: '/images/area-hr.jpg',
    description:
      "As a company which is growing and changing, Kaplan International is a stimulating environment for HR professionals – whether it's facilitating training, supporting on recruitment and selection, providing information and advice on benefits or assisting a line manager with staff development or offering advice to employees on career development or ensuring that HR policies are applied appropriately across the business.",
  },
];
---
<section id="career-area" class="section career-area" aria-labelledby="career-title">
  <div class="container">
    <div class="reveal">
      <h2 class="section-title" id="career-title">Career Areas</h2>
      <p class="section-subtitle">
        With roles across almost every discipline from teaching and operations through IT, Finance,
        Sales and Marketing, Kaplan International employs individuals with a wide range of
        professional backgrounds and are always on the lookout for talented people.
      </p>
    </div>

    <!-- Tile grid + panel container -->
    <div class="ca-accordion" id="career-accordion" role="list">
      <div class="ca-tiles" role="presentation">
        {areas.map((area) => (
          <div class="ca-tile reveal" role="listitem">
            <button
              class="ca-trigger"
              id={`ca-btn-${area.id}`}
              aria-expanded="false"
              aria-controls={`ca-panel-${area.id}`}
              data-area-id={area.id}
            >
              <div
                class="ca-trigger__bg"
                style={`background-image:url('${area.image}')`}
                aria-hidden="true"
              ></div>
              <div class="ca-trigger__overlay" aria-hidden="true"></div>
              <span class="ca-trigger__label">
                <span class="ca-trigger__title">{area.title}</span>
                <span class="ca-trigger__toggle" aria-hidden="true">
                  <span class="ca-toggle-icon"></span>
                </span>
              </span>
            </button>
          </div>
        ))}
      </div>

      <!-- Panels injected below the row of the active tile -->
      {areas.map((area) => (
        <div
          class="ca-panel"
          id={`ca-panel-${area.id}`}
          role="region"
          aria-labelledby={`ca-btn-${area.id}`}
          hidden
          data-area-id={area.id}
          style={`background-image:url('${area.image}')`}
        >
          <div class="ca-panel__overlay" aria-hidden="true"></div>
          <div class="container ca-panel__inner">
            <h3 class="ca-panel__title">{area.title}</h3>
            <p class="ca-panel__desc">{area.description}</p>
            <button
              class="btn btn-md btn-skyblue ca-panel__cta"
              data-modal="location-modal"
              aria-haspopup="dialog"
            >
              Current opportunities
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .career-area {
    background: var(--color-light-grey);
  }

  /* Tile grid */
  .ca-tiles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  @media (max-width: 767px) {
    .ca-tiles { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 479px) {
    .ca-tiles { grid-template-columns: 1fr; }
  }

  .ca-trigger {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    border: none;
    cursor: pointer;
    overflow: hidden;
    border-radius: var(--radius-md);
    display: flex;
    align-items: flex-end;
    padding: 0;
    background: var(--color-navy-dark);
    transition: box-shadow var(--transition-normal);
  }
  .ca-trigger:hover, .ca-trigger:focus-visible {
    box-shadow: var(--shadow-card-hover);
    outline: none;
  }
  .ca-trigger:focus-visible::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-md);
    outline: 3px solid var(--color-focus-ring);
    outline-offset: 2px;
  }
  .ca-trigger[aria-expanded="true"] {
    box-shadow: 0 0 0 3px var(--color-primary);
  }

  .ca-trigger__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform var(--transition-slow);
  }
  .ca-trigger:hover .ca-trigger__bg,
  .ca-trigger[aria-expanded="true"] .ca-trigger__bg {
    transform: scale(1.05);
  }

  .ca-trigger__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(18,27,96,0.85) 0%, rgba(2,3,10,0.3) 70%);
    transition: background var(--transition-normal);
  }
  .ca-trigger[aria-expanded="true"] .ca-trigger__overlay {
    background: linear-gradient(to top, rgba(0,165,217,0.75) 0%, rgba(18,27,96,0.5) 100%);
  }

  .ca-trigger__label {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: var(--space-4);
    gap: var(--space-2);
  }

  .ca-trigger__title {
    color: var(--color-white);
    font-size: var(--text-base);
    font-weight: 700;
    text-align: left;
    line-height: var(--leading-snug);
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  .ca-toggle-icon {
    display: block;
    width: 16px;
    height: 16px;
    position: relative;
    flex-shrink: 0;
  }
  .ca-toggle-icon::before,
  .ca-toggle-icon::after {
    content: '';
    position: absolute;
    background: var(--color-white);
    border-radius: 2px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }
  .ca-toggle-icon::before {
    width: 16px; height: 2px;
    top: 7px; left: 0;
  }
  .ca-toggle-icon::after {
    width: 2px; height: 16px;
    top: 0; left: 7px;
  }
  .ca-trigger[aria-expanded="true"] .ca-toggle-icon::after {
    transform: rotate(90deg);
    opacity: 0;
  }

  /* Panel */
  .ca-panel {
    width: 100%;
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    margin-top: var(--space-4);
  }
  .ca-panel[hidden] { display: none; }
  .ca-panel.is-animating { display: block; }

  .ca-panel__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(18,27,96,0.92) 0%, rgba(18,27,96,0.6) 100%);
  }

  .ca-panel__inner {
    position: relative;
    z-index: 1;
    padding-block: var(--space-12);
    max-width: 640px;
  }

  .ca-panel__title {
    color: var(--color-white);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .ca-panel__desc {
    color: rgba(255,255,255,0.88);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }
</style>

<script>
  (() => {
    const accordion = document.getElementById('career-accordion');
    if (!accordion) return;

    const buttons = accordion.querySelectorAll<HTMLButtonElement>('.ca-trigger');
    const panels  = accordion.querySelectorAll<HTMLElement>('.ca-panel');

    const tilesContainer = accordion.querySelector<HTMLElement>('.ca-tiles');

    function closeAll() {
      buttons.forEach(btn => btn.setAttribute('aria-expanded', 'false'));
      panels.forEach(panel => {
        panel.hidden = true;
        panel.classList.remove('is-animating');
      });
    }

    function openPanel(areaId: string) {
      const btn   = accordion.querySelector<HTMLButtonElement>(`[data-area-id="${areaId}"].ca-trigger`);
      const panel = accordion.querySelector<HTMLElement>(`#ca-panel-${areaId}`);
      if (!btn || !panel) return;

      btn.setAttribute('aria-expanded', 'true');
      panel.hidden = false;

      // Insert panel after tiles container
      tilesContainer?.after(panel);

      // Animate in
      panel.classList.add('is-animating');
      requestAnimationFrame(() => panel.classList.add('is-animating'));
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const areaId   = btn.dataset.areaId!;
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        closeAll();
        if (!expanded) openPanel(areaId);
      });

      btn.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') closeAll();
      });
    });
  })();
</script>
