---
// src/components/sections/OurPeople.astro

const testimonials = [
  {
    name: 'William',
    role: 'Admissions',
    image: '/images/ki-staff-william.jpg',
    quote:
      "Working in Admissions at Kaplan International means I'm often the first point of contact for students embarking on a life-changing experience. It's incredibly rewarding to guide someone through the process and see them arrive excited and ready to begin their journey.",
  },
  {
    name: 'Ersilia',
    role: 'Customer Care',
    image: '/images/ki-staff-ersilia.jpg',
    quote:
      "The diversity of our student body makes every day different. In Customer Care, I get to support people from all over the world, and the multilingual environment means there's always something new to learn. The team here is genuinely like a family.",
  },
  {
    name: 'Rachel',
    role: 'Teaching',
    image: '/images/ki-staff-rachel.jpg',
    quote:
      "Teaching at Kaplan International is about more than just language — it's about opening doors for students. Watching someone gain confidence and achieve their academic goals is what motivates me to come in every day. The support from management makes all the difference.",
  },
];
---
<section id="ki-staff" class="section section--dark our-people" aria-labelledby="staff-title">
  <div class="container">
    <div class="reveal">
      <h2 class="section-title" id="staff-title">Hear from our staff</h2>
    </div>

    <div class="testimonial-grid">
      {testimonials.map((t, i) => (
        <article class="testimonial reveal" style={`animation-delay:${i * 0.15}s`}>
          <div class="testimonial__photo-wrap">
            <img
              src={t.image}
              alt={t.name}
              class="testimonial__photo"
              loading="lazy"
              width="120"
              height="120"
            />
          </div>
          <blockquote class="testimonial__quote">
            <p>{t.quote}</p>
          </blockquote>
          <footer class="testimonial__footer">
            <strong class="testimonial__name">{t.name}</strong>
            <span class="testimonial__role">{t.role}</span>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .our-people {
    /* dark navy bg from section--dark */
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-8);
    margin-top: var(--space-4);
  }

  .testimonial {
    background: rgba(255,255,255,0.06);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
    border: 1px solid rgba(255,255,255,0.1);
    transition: background var(--transition-normal);
  }
  .testimonial:hover {
    background: rgba(255,255,255,0.1);
  }

  .testimonial__photo-wrap {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-primary);
    flex-shrink: 0;
    background: var(--color-navy);
  }
  .testimonial__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .testimonial__quote {
    margin: 0;
    flex: 1;
  }
  .testimonial__quote p {
    color: rgba(255,255,255,0.85);
    font-size: var(--text-md);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    font-style: italic;
  }
  .testimonial__quote p::before { content: '\201C'; }
  .testimonial__quote p::after  { content: '\201D'; }

  .testimonial__footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .testimonial__name {
    color: var(--color-primary);
    font-size: var(--text-base);
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
  }
  .testimonial__role {
    color: rgba(255,255,255,0.55);
    font-size: var(--text-sm);
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }
</style>
