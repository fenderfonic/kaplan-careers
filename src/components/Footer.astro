---
// src/components/Footer.astro
import { SITE } from '../config/site.ts';

const year = new Date().getFullYear();

// Country partner links (kaptestglobal.com)
const partnerLinks = [
  { label: 'Australia',      href: 'https://www.kaptestglobal.com/kceps/au' },
  { label: 'Brazil',         href: 'https://www.kaptestglobal.com/kceps/br' },
  { label: 'Canada',         href: 'https://www.kaptestglobal.com/kceps/ca' },
  { label: 'China',          href: 'https://www.kaptestglobal.com/kceps/cn' },
  { label: 'France',         href: 'https://www.kaptestglobal.com/kceps/fr' },
  { label: 'Germany',        href: 'https://www.kaptestglobal.com/kceps/de' },
  { label: 'Hong Kong',      href: 'https://www.kaplan.com.hk' },
  { label: 'India',          href: 'https://www.kaptestglobal.com/kceps/in' },
  { label: 'Ireland',        href: 'https://www.kaptestglobal.com/kceps/ie' },
  { label: 'Japan',          href: 'https://www.kaptestglobal.com/kceps/jp' },
  { label: 'Malaysia',       href: 'https://www.kaptestglobal.com/kceps/my' },
  { label: 'Mexico',         href: 'https://www.kaptestglobal.com/kceps/mx' },
  { label: 'New Zealand',    href: 'https://www.kaptestglobal.com/kceps/nz' },
  { label: 'Singapore',      href: 'https://www.kaplan.com.sg' },
  { label: 'South Korea',    href: 'https://www.kaptestglobal.com/kceps/kr' },
  { label: 'Spain',          href: 'https://www.kaptestglobal.com/kceps/es' },
  { label: 'Taiwan',         href: 'https://www.kaptestglobal.com/kceps/tw' },
  { label: 'United Kingdom', href: 'https://www.kaplaninternational.com' },
  { label: 'United States',  href: 'https://www.kaptestglobal.com/kceps/us' },
  { label: 'Vietnam',        href: 'https://www.kaptestglobal.com/kceps/vn' },
];

const socialLinks = [
  { label: 'LinkedIn',  href: 'https://www.linkedin.com/company/kaplan-international', icon: 'in' },
  { label: 'Facebook',  href: 'https://www.facebook.com/KaplanInternational', icon: 'f' },
  { label: 'Twitter/X', href: 'https://twitter.com/KaplanIntl', icon: 'x' },
  { label: 'Instagram', href: 'https://www.instagram.com/kaplaninternational/', icon: 'ig' },
];
---
<footer class="site-footer" role="contentinfo">
  <!-- Partner directory -->
  <div class="footer-partners">
    <div class="container">
      <h2 class="footer-partners__heading">Explore Kaplan worldwide</h2>
      <ul class="footer-partners__list" role="list">
        {partnerLinks.map(link => (
          <li>
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-partner-link"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Footer bottom -->
  <div class="footer-bottom">
    <div class="container footer-bottom__inner">
      <!-- Logo + links -->
      <div class="footer-brand">
        <img
          src="/images/ki-logo.svg"
          alt="Kaplan International"
          class="footer-logo"
          width="100"
          height="34"
          loading="lazy"
          onerror="this.style.display='none'"
        />
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href="/gender-pay-gap" class="footer-nav__link">Gender Pay Gap</a>
          <button
            class="footer-nav__link footer-nav__btn"
            data-modal="contact-modal"
            aria-haspopup="dialog"
          >
            Contact us
          </button>
        </nav>
      </div>

      <!-- Social -->
      <div class="footer-social" aria-label="Social media links">
        {socialLinks.map(s => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social__link"
            aria-label={`${s.label} (opens in new tab)`}
          >
            <span aria-hidden="true" class="footer-social__icon">{s.icon}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Legal -->
    <div class="container">
      <p class="footer-legal">
        &copy; {year} {SITE.legalEntity},
        Reg No: {SITE.legalRegNo} /
        VAT No: {SITE.legalVatNo} /
        Reg office: {SITE.legalAddress}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-navy-darkest);
    color: rgba(255,255,255,0.6);
  }

  /* Partners */
  .footer-partners {
    background: rgba(255,255,255,0.04);
    padding-block: var(--space-12) var(--space-8);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .footer-partners__heading {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: rgba(255,255,255,0.45);
    margin-bottom: var(--space-6);
  }
  .footer-partners__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
  }
  .footer-partner-link {
    color: rgba(255,255,255,0.55);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .footer-partner-link:hover { color: var(--color-primary); }

  /* Bottom */
  .footer-bottom {
    padding-block: var(--space-8);
  }
  .footer-bottom__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    flex-wrap: wrap;
  }
  .footer-logo {
    height: 30px;
    width: auto;
    opacity: 0.7;
    filter: brightness(0) invert(1);
  }

  .footer-nav {
    display: flex;
    gap: var(--space-6);
    align-items: center;
  }
  .footer-nav__link {
    color: rgba(255,255,255,0.55);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: color var(--transition-fast);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: var(--font-body);
  }
  .footer-nav__link:hover { color: var(--color-primary); }

  /* Social */
  .footer-social {
    display: flex;
    gap: var(--space-3);
  }
  .footer-social__link {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    font-size: var(--text-xs);
    font-weight: 700;
    transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
  }
  .footer-social__link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: rgba(0,165,217,0.1);
  }

  /* Legal */
  .footer-legal {
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.35);
    line-height: var(--leading-relaxed);
  }
</style>
