---
// src/components/ui/ContactModal.astro
import { SITE } from '../../config/site.ts';
---
<div
  class="modal-backdrop"
  id="contact-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="contact-modal-title"
  hidden
>
  <div class="modal-dialog contact-modal">
    <div class="modal-header">
      <h2 class="modal-title" id="contact-modal-title">✉ Contact us</h2>
      <button
        class="modal-close"
        aria-label="Close contact modal"
        data-modal-close="contact-modal"
      >
        ✕
      </button>
    </div>
    <div class="modal-body">
      <p class="contact-intro">
        Get in touch with our recruitment team for any questions about careers at Kaplan International.
      </p>
      <dl class="contact-details">
        <div class="contact-item">
          <dt>
            <span aria-hidden="true" class="contact-icon">📍</span>
            <span class="visually-hidden">Address</span>
          </dt>
          <dd>
            {SITE.contactAddress}
          </dd>
        </div>
        <div class="contact-item">
          <dt>
            <span aria-hidden="true" class="contact-icon">☎</span>
            <span class="visually-hidden">Phone</span>
          </dt>
          <dd>
            <a href={`tel:${SITE.contactPhone.replace(/\s/g,'')}`} class="contact-link">
              {SITE.contactPhone}
            </a>
          </dd>
        </div>
        <div class="contact-item">
          <dt>
            <span aria-hidden="true" class="contact-icon">✉</span>
            <span class="visually-hidden">Email</span>
          </dt>
          <dd>
            <a href={`mailto:${SITE.contactEmail}`} class="contact-link">
              {SITE.contactEmail}
            </a>
          </dd>
        </div>
      </dl>
    </div>
  </div>
</div>

<style>
  .contact-modal {
    max-width: 480px;
  }

  .contact-intro {
    font-size: var(--text-md);
    color: var(--color-mid-grey);
    margin-bottom: var(--space-6);
    line-height: var(--leading-relaxed);
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }
  .contact-item dt {
    flex-shrink: 0;
    width: 2rem;
  }
  .contact-icon {
    font-size: var(--text-xl);
  }
  .contact-item dd {
    color: var(--color-body-text);
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    margin: 0;
  }
  .contact-link {
    color: var(--color-primary);
    text-decoration: none;
  }
  .contact-link:hover {
    text-decoration: underline;
    color: var(--color-primary-dark);
  }
</style>
