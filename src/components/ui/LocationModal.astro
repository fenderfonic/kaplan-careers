---
// src/components/ui/LocationModal.astro
import { REGION_ATS } from '../../config/site.ts';
---
<div
  class="modal-backdrop"
  id="location-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="location-modal-title"
  hidden
>
  <div class="modal-dialog location-modal">
    <div class="modal-header">
      <h2 class="modal-title" id="location-modal-title">
        📍 Pick your location
      </h2>
      <button
        class="modal-close"
        aria-label="Close location picker"
        data-modal-close="location-modal"
      >
        ✕
      </button>
    </div>
    <div class="modal-body">
      <p class="location-modal__intro">
        Select your region to view current job opportunities at Kaplan International.
      </p>
      <div class="region-tiles">
        {REGION_ATS.map(region => (
          <a
            href={region.url}
            target="_blank"
            rel="noopener noreferrer"
            class="region-tile"
            aria-label={`${region.label} — opens in new tab`}
          >
            <span class="region-tile__icon" aria-hidden="true">{region.icon}</span>
            <span class="region-tile__label">{region.label}</span>
            <span class="region-tile__desc">{region.desc}</span>
            <span class="region-tile__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .location-modal {
    max-width: 560px;
  }

  .location-modal__intro {
    font-size: var(--text-md);
    color: var(--color-mid-grey);
    margin-bottom: var(--space-6);
  }

  .region-tiles {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .region-tile {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    grid-template-rows: auto auto;
    align-items: center;
    gap: 0 var(--space-4);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-body-text);
    transition: border-color var(--transition-fast),
                background var(--transition-fast),
                box-shadow var(--transition-fast);
  }
  .region-tile:hover, .region-tile:focus-visible {
    border-color: var(--color-primary);
    background: rgba(0,165,217,0.04);
    box-shadow: 0 2px 8px rgba(0,165,217,0.12);
    outline: none;
  }
  .region-tile:focus-visible {
    outline: 3px solid var(--color-focus-ring);
    outline-offset: 2px;
  }

  .region-tile__icon {
    font-size: 1.75rem;
    grid-row: 1 / 3;
    grid-column: 1;
    display: flex;
    align-items: center;
  }
  .region-tile__label {
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-navy);
    grid-column: 2;
    grid-row: 1;
  }
  .region-tile__desc {
    font-size: var(--text-sm);
    color: var(--color-muted-grey);
    font-weight: 300;
    grid-column: 2;
    grid-row: 2;
  }
  .region-tile__arrow {
    grid-column: 3;
    grid-row: 1 / 3;
    color: var(--color-primary);
    font-size: var(--text-xl);
    opacity: 0.6;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }
  .region-tile:hover .region-tile__arrow {
    opacity: 1;
    transform: translateX(4px);
  }
</style>
