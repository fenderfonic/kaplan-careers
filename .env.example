# ============================================================
# KAPLAN INTERNATIONAL CAREERS — Integration Config Reference
# ============================================================
# All values discovered during recon of careers.kaplaninternational.com
# Copy to .env (or .env.local for Astro/Next) and fill in live values.
# Never commit actual secrets — this file documents keys and defaults only.
# ============================================================


# ------------------------------------------------------------
# SITE
# ------------------------------------------------------------
PUBLIC_SITE_URL=https://careers.kaplaninternational.com
PUBLIC_SITE_TITLE=Join our Global Team | Kaplan International
PUBLIC_CANONICAL_URL=//careers.kaplaninternational.com

# Legal entity shown in footer copyright
PUBLIC_LEGAL_ENTITY=Aspect International Language Academies Ltd
PUBLIC_LEGAL_REG_NO=2162156
PUBLIC_LEGAL_VAT_NO=152088224
PUBLIC_LEGAL_ADDRESS=Palace House, 3 Cathedral Street, London SE1 9DE, United Kingdom


# ------------------------------------------------------------
# ANALYTICS — Google Tag Manager
# Found in: <head> of careers.kaplaninternational.com
# Fires GA and any other tags via the container
# ------------------------------------------------------------
PUBLIC_GTM_CONTAINER_ID=GTM-T7R98LC


# ------------------------------------------------------------
# A/B TESTING — Optimizely
# Found in: <script src="//cdn.optimizely.com/js/4238035597.js">
# Loaded synchronously in <head> — blocks render intentionally
# ------------------------------------------------------------
PUBLIC_OPTIMIZELY_PROJECT_ID=4238035597


# ------------------------------------------------------------
# COOKIE BANNER
# Shared Kaplan asset hosted on assetlibs subdomain
# Configured via cookieLanguage JS variable before the script tag
# ------------------------------------------------------------
PUBLIC_COOKIE_BANNER_URL=https://assetlibs.kaplaninternational.com/_assets/cookie-banner/js/cookieconsent.min.js
PUBLIC_COOKIE_LANGUAGE=en


# ------------------------------------------------------------
# ATS — EMEA / UK / Ireland: HireHive
# my.hirehive.io redirects 301 → kaplan-international.hirehive.com
# Company ID 7012 is used in HireHive asset CDN paths
# ------------------------------------------------------------
PUBLIC_ATS_EMEA_PLATFORM=hirehive
PUBLIC_ATS_EMEA_URL=https://my.hirehive.io/kaplan-international/
PUBLIC_ATS_EMEA_RESOLVED_URL=https://kaplan-international.hirehive.com
PUBLIC_ATS_EMEA_COMPANY_ID=7012
PUBLIC_ATS_EMEA_LABEL=Jobs in UK, Ireland and Rest of EMEA

# HireHive direct API integration (not used by original site — for future embed)
# Docs: https://hirehive.com/developers/
# PUBLIC_HIREHIVE_API_KEY=


# ------------------------------------------------------------
# ATS — USA / Canada: Workday
# Tenant is "ghc" = Graham Holdings Company (Kaplan's parent group)
# Workday is JS-rendered — curl only returns an 8KB shell
# ------------------------------------------------------------
PUBLIC_ATS_USA_PLATFORM=workday
PUBLIC_ATS_USA_URL=https://ghc.wd1.myworkdayjobs.com/Kaplan_International_Careers
PUBLIC_ATS_USA_TENANT=ghc
PUBLIC_ATS_USA_CAREER_SITE=Kaplan_International_Careers
PUBLIC_ATS_USA_LABEL=Jobs in the USA and Canada

# Workday API credentials (if embedding job feed — requires Workday tenant setup)
# PUBLIC_WORKDAY_CLIENT_ID=
# PUBLIC_WORKDAY_CLIENT_SECRET=
# PUBLIC_WORKDAY_TOKEN_URL=https://ghc.myworkday.com/ccx/oauth2/token


# ------------------------------------------------------------
# ATS — Australia / New Zealand: ApplyNow (PageUp)
# Ruby on Rails app on AWS CloudFront
# Has its own GA4 (G-830SMPP9XE) and Pendo analytics
# ------------------------------------------------------------
PUBLIC_ATS_ANZ_PLATFORM=applynow
PUBLIC_ATS_ANZ_URL=https://kaplan.applynow.net.au/
PUBLIC_ATS_ANZ_LABEL=Jobs in Australia and New Zealand

# ApplyNow / PageUp API (if embedding job feed)
# PUBLIC_APPLYNOW_API_KEY=


# ------------------------------------------------------------
# ATS — Singapore: Kaplan.com.sg
# Jobs embedded in main Kaplan Singapore website (not a standalone ATS)
# ------------------------------------------------------------
PUBLIC_ATS_SG_PLATFORM=kaplan-sg
PUBLIC_ATS_SG_URL=https://www.kaplan.com.sg/careers/
PUBLIC_ATS_SG_LABEL=Jobs in Singapore


# ------------------------------------------------------------
# ATS — Hong Kong: Kaplan.com.hk
# PHP-based Kaplan HK site
# ------------------------------------------------------------
PUBLIC_ATS_HK_PLATFORM=kaplan-hk
PUBLIC_ATS_HK_URL=https://www.kaplan.com.hk/careers-at-kaplan_join-our-team.php
PUBLIC_ATS_HK_LABEL=Jobs in Hong Kong


# ------------------------------------------------------------
# CONTACT / RECRUITMENT TEAM
# Shown in ki-contact-popup modal
# Email is Cloudflare-obfuscated in source HTML
# ------------------------------------------------------------
PUBLIC_RECRUITMENT_EMAIL=kaplanstaff.recruitment@kaplan.com
PUBLIC_RECRUITMENT_PHONE=+44 (0)20 8727 3500
PUBLIC_RECRUITMENT_ADDRESS_LINE1=Recruitment team
PUBLIC_RECRUITMENT_ADDRESS_LINE2=Palace House
PUBLIC_RECRUITMENT_ADDRESS_LINE3=3 Cathedral Street
PUBLIC_RECRUITMENT_ADDRESS_CITY=London
PUBLIC_RECRUITMENT_ADDRESS_POSTCODE=SE1 9DE
PUBLIC_RECRUITMENT_ADDRESS_COUNTRY=United Kingdom


# ------------------------------------------------------------
# FONTS
# Google Fonts — no API key required, loaded via CSS @import
# ------------------------------------------------------------
PUBLIC_GOOGLE_FONTS_URL=https://fonts.googleapis.com/css?family=Lato:100,300,400,700,900&subset=latin-ext


# ------------------------------------------------------------
# FAVICON
# Currently loaded from the study subdomain — rehost if rebuilding
# ------------------------------------------------------------
PUBLIC_FAVICON_URL=https://study.kaplaninternational.com/favicon.ico


# ------------------------------------------------------------
# HERO VIDEO
# Vide.js auto-appends .mp4 / .webm / .ogv to this base path
# For a rebuild, use native HTML5 <video autoplay muted loop playsinline>
# ------------------------------------------------------------
PUBLIC_HERO_VIDEO_PATH=dist/video/ki-career
# If hosting video on CDN:
# PUBLIC_HERO_VIDEO_CDN_URL=https://your-cdn.com/video/ki-career


# ------------------------------------------------------------
# OPEN GRAPH / SEO
# ------------------------------------------------------------
PUBLIC_OG_TITLE=Join our Global Team | Kaplan International
PUBLIC_OG_DESCRIPTION=We're Looking for People to Make a Difference. Start a New and exciting Career at Kaplan
PUBLIC_OG_IMAGE=https://careers.kaplaninternational.com/dist/images/business-kaplan-int-english.jpg
PUBLIC_META_DESCRIPTION=Join our Global Team. Learn more about our education business to see where you could apply your skills | Kaplan International
PUBLIC_META_PAGE_TYPE=gcpn_kaplan-new-campaign


# ------------------------------------------------------------
# PARTNER / SIBLING SITE LINKS
# Used in business area descriptions and footer country list
# ------------------------------------------------------------
PUBLIC_PARTNER_KI_LANGUAGES=https://www.kaplaninternational.com
PUBLIC_PARTNER_KI_PATHWAYS=https://www.kaplanpathways.com
PUBLIC_PARTNER_KAPLAN_SG=https://www.kaplan.com.sg
PUBLIC_PARTNER_KAPLAN_SG_PROFESSIONAL=https://www.kaplan.com.sg/professional
PUBLIC_PARTNER_KAPLAN_HK=https://www.kaplan.com.hk
PUBLIC_PARTNER_KAPLAN_FINANCE_HK=https://www.kaplanfinancial.com.hk/kf/index.php
PUBLIC_PARTNER_KAPLAN_PROFESSIONAL_AU=https://www.kaplanprofessional.edu.au
PUBLIC_PARTNER_KBS_AU=https://www.kbs.edu.au
PUBLIC_PARTNER_MURDOCH_INSTITUTE=https://www.murdochinstitute.wa.edu.au
PUBLIC_PARTNER_BRADFORD_ADELAIDE=https://www.bradford.adelaide.edu.au
PUBLIC_PARTNER_GLOBAL_PATHWAYS_US=https://www.global-pathways.com
PUBLIC_PARTNER_KAPTEST_GLOBAL=https://www.kaptestglobal.com
PUBLIC_PARTNER_ALPADIA=https://www.alpadia.com/en/work-for-us
PUBLIC_PARTNER_ESL=https://www.esl.co.uk/en/about/jobs


# ------------------------------------------------------------
# FEATURE FLAGS
# Suggested for new build — not present in original site.
# Toggle integrations per environment without code changes.
# ------------------------------------------------------------
# ENABLE_GTM=true
# ENABLE_OPTIMIZELY=true
# ENABLE_COOKIE_BANNER=true

# Set to true to embed job listings inline instead of linking out to ATS
# ENABLE_HIREHIVE_EMBED=false
# ENABLE_WORKDAY_EMBED=false
# ENABLE_APPLYNOW_EMBED=false
